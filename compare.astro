---
// src/pages/compare.astro
// Suburb comparison tool — accepts ?a=suburb-slug&b=suburb-slug in URL
import { getCollection } from 'astro:content';

const suburbs = await getCollection('suburbs');
const aParam = Astro.url.searchParams.get('a') ?? '';
const bParam = Astro.url.searchParams.get('b') ?? '';

const subA = suburbs.find(s => s.slug === aParam);
const subB = suburbs.find(s => s.slug === bParam);

const metrics = [
  { label: 'Scout Score', keyA: 'scout_score', keyB: 'scout_score', suffix: '/10', higherIsBetter: true },
  { label: 'Median house price', keyA: 'median_house_price', keyB: 'median_house_price', prefix: '$', isPrice: true, higherIsBetter: false },
  { label: 'Median weekly rent', keyA: 'median_rent_pw', keyB: 'median_rent_pw', prefix: '$', suffix: '/wk', higherIsBetter: false },
  { label: '5-year price growth', keyA: 'price_growth_5yr', keyB: 'price_growth_5yr', suffix: '%', higherIsBetter: true },
  { label: 'Crime rank (lower = safer)', keyA: 'crime_rank', keyB: 'crime_rank', higherIsBetter: false },
  { label: 'CBD by train', keyA: 'commute_train_mins', keyB: 'commute_train_mins', suffix: ' min', higherIsBetter: false },
  { label: 'Safety rating', keyA: 'rating_safety', keyB: 'rating_safety', suffix: '/10', higherIsBetter: true },
  { label: 'Transport rating', keyA: 'rating_transport', keyB: 'rating_transport', suffix: '/10', higherIsBetter: true },
  { label: 'Family friendliness', keyA: 'rating_family', keyB: 'rating_family', suffix: '/10', higherIsBetter: true },
  { label: 'Things to do', keyA: 'rating_things_to_do', keyB: 'rating_things_to_do', suffix: '/10', higherIsBetter: true },
  { label: 'Affordability (buying)', keyA: 'rating_affordability_buy', keyB: 'rating_affordability_buy', suffix: '/10', higherIsBetter: true },
  { label: 'Affordability (renting)', keyA: 'rating_affordability_rent', keyB: 'rating_affordability_rent', suffix: '/10', higherIsBetter: true },
  { label: 'Flood risk', keyA: 'flood_risk', keyB: 'flood_risk', isText: true },
  { label: 'Bushfire risk', keyA: 'bushfire_risk', keyB: 'bushfire_risk', isText: true },
];

function winner(valA: any, valB: any, higherIsBetter: boolean) {
  if (valA === undefined || valB === undefined) return null;
  if (higherIsBetter) return valA > valB ? 'a' : valA < valB ? 'b' : 'tie';
  return valA < valB ? 'a' : valA > valB ? 'b' : 'tie';
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    {subA && subB
      ? `${subA.data.name} vs ${subB.data.name} — Suburb Comparison | SuburbScout`
      : 'Compare Australian Suburbs | SuburbScout'}
  </title>
  <meta name="description" content={subA && subB
    ? `Compare ${subA.data.name} and ${subB.data.name} side-by-side: property prices, crime, schools, commute times and more.`
    : 'Compare any two Australian suburbs side by side on SuburbScout.'} />
  <link rel="stylesheet" href="/styles/global.css" />
  <style>
    .compare-wrap { max-width: 900px; margin: 32px auto; padding: 0 20px 48px; }
    .compare-header { display: grid; grid-template-columns: 220px 1fr 1fr; gap: 0; margin-bottom: 0; }
    .col-label { padding: 16px; background: #f7f7f5; border: 1px solid #e0e0e0; font-size: 13px; font-weight: 600; color: #666; display: flex; align-items: center; }
    .col-a, .col-b { padding: 16px; text-align: center; border: 1px solid #e0e0e0; border-left: none; }
    .col-a { background: #e8f5ed; }
    .col-b { background: #e6f0fb; }
    .col-name { font-family: 'Sora', sans-serif; font-size: 18px; font-weight: 700; margin-bottom: 4px; }
    .col-sub { font-size: 12px; color: #666; }
    .row { display: grid; grid-template-columns: 220px 1fr 1fr; }
    .row:nth-child(even) .col-label { background: white; }
    .row:nth-child(even) .metric-a, .row:nth-child(even) .metric-b { background: white; }
    .metric-a, .metric-b { padding: 14px 16px; text-align: center; border: 1px solid #e0e0e0; border-top: none; border-left: none; font-size: 15px; font-weight: 500; background: #f9f9f9; }
    .metric-a { border-left: 1px solid #e0e0e0; }
    .win { background: #d4edda !important; font-weight: 700; color: #1a6b3a; }
    .search-row { display: flex; gap: 12px; margin-bottom: 28px; align-items: flex-end; }
    .search-row > div { flex: 1; }
    .search-row label { display: block; font-size: 12px; font-weight: 600; margin-bottom: 5px; color: #666; }
    .search-row select { width: 100%; padding: 10px 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 14px; }
    .btn-compare-go { background: #1a6b3a; color: white; border: none; padding: 10px 24px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; height: 42px; }
    .page-title { font-family: 'Sora', sans-serif; font-size: 28px; font-weight: 700; margin-bottom: 6px; }
    .page-sub { font-size: 14px; color: #666; margin-bottom: 24px; }
    .ad-compare { background: #f0f0ee; border: 1px solid #e0e0e0; border-radius: 10px; padding: 12px; text-align: center; margin: 24px 0; min-height: 100px; }
  </style>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX" crossorigin="anonymous"></script>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>

  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="logo">
        <span class="logo-mark">S</span>
        <span class="logo-text">SuburbScout</span>
      </a>
      <nav class="nav">
        <a href="/compare">Compare</a>
        <a href="/quiz">Find My Suburb</a>
        <a href="/top-10">Top 10 Lists</a>
        <a href="/tools">Tools</a>
      </nav>
    </div>
  </header>

  <div class="compare-wrap">
    <h1 class="page-title">
      {subA && subB
        ? `${subA.data.name} vs ${subB.data.name}`
        : 'Compare Australian suburbs'}
    </h1>
    <p class="page-sub">Select two suburbs to compare side by side across price, crime, transport, schools and lifestyle.</p>

    <!-- Suburb selector -->
    <form class="search-row" method="get" action="/compare">
      <div>
        <label>Suburb A</label>
        <select name="a">
          <option value="">Select suburb…</option>
          {suburbs.map(s => (
            <option value={s.slug} selected={s.slug === aParam}>{s.data.name}, {s.data.state}</option>
          ))}
        </select>
      </div>
      <div>
        <label>Suburb B</label>
        <select name="b">
          <option value="">Select suburb…</option>
          {suburbs.map(s => (
            <option value={s.slug} selected={s.slug === bParam}>{s.data.name}, {s.data.state}</option>
          ))}
        </select>
      </div>
      <button type="submit" class="btn-compare-go">Compare</button>
    </form>

    {subA && subB && (
      <>
        <!-- Ad -->
        <div class="ad-compare">
          <p style="font-size:10px;color:#aaa;text-transform:uppercase;margin-bottom:4px">Advertisement</p>
          <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-XXXXXXXXXXXXXXXX" data-ad-slot="9988776655" data-ad-format="auto" data-full-width-responsive="true"></ins>
          <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>

        <!-- Comparison table -->
        <div>
          <div class="compare-header">
            <div class="col-label">Metric</div>
            <div class="col-a">
              <div class="col-name">{subA.data.name}</div>
              <div class="col-sub">{subA.data.state} {subA.data.postcode}</div>
            </div>
            <div class="col-b">
              <div class="col-name">{subB.data.name}</div>
              <div class="col-sub">{subB.data.state} {subB.data.postcode}</div>
            </div>
          </div>

          {metrics.map(m => {
            const valA = subA.data[m.keyA];
            const valB = subB.data[m.keyB];
            const w = m.isText ? null : winner(valA, valB, m.higherIsBetter ?? true);

            function fmt(val: any) {
              if (val === undefined || val === null) return '—';
              if (m.isText) return val;
              if (m.isPrice) return `$${Number(val).toLocaleString()}`;
              return `${m.prefix ?? ''}${val}${m.suffix ?? ''}`;
            }

            return (
              <div class="row">
                <div class="col-label">{m.label}</div>
                <div class={`metric-a ${w === 'a' ? 'win' : ''}`}>{fmt(valA)}</div>
                <div class={`metric-b ${w === 'b' ? 'win' : ''}`}>{fmt(valB)}</div>
              </div>
            );
          })}
        </div>

        <!-- View full profiles -->
        <div style="display:flex;gap:12px;margin-top:24px">
          <a href={`/${subA.data.state.toLowerCase()}/${subA.slug}`} class="btn-green">Full {subA.data.name} profile →</a>
          <a href={`/${subB.data.state.toLowerCase()}/${subB.slug}`} class="btn-green">Full {subB.data.name} profile →</a>
        </div>
      </>
    )}
  </div>

</body>
</html>
