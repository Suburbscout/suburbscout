---
// src/pages/quiz.astro
// "Find My Suburb" quiz — high engagement, highly shareable
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Find My Perfect Suburb Quiz — SuburbScout Australia</title>
  <meta name="description" content="Answer 8 quick questions and SuburbScout will recommend the best Australian suburbs for your lifestyle, budget and priorities. Free suburb match quiz." />
  <link rel="stylesheet" href="/styles/global.css" />
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX" crossorigin="anonymous"></script>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    .quiz-wrap { max-width: 680px; margin: 40px auto; padding: 0 20px 60px; }
    .quiz-title { font-family: 'Sora', sans-serif; font-size: 30px; font-weight: 700; margin-bottom: 8px; }
    .quiz-sub { font-size: 15px; color: #666; margin-bottom: 32px; }
    .progress-bar-bg { height: 6px; background: #e0e0e0; border-radius: 3px; margin-bottom: 32px; }
    .progress-bar-fill { height: 6px; background: #1a6b3a; border-radius: 3px; transition: width 0.3s; }
    .question-card { background: white; border: 1px solid #e0e0e0; border-radius: 14px; padding: 28px; margin-bottom: 20px; }
    .q-num { font-size: 12px; color: #999; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px; }
    .q-text { font-family: 'Sora', sans-serif; font-size: 20px; font-weight: 600; margin-bottom: 20px; }
    .options { display: flex; flex-direction: column; gap: 10px; }
    .opt { padding: 13px 18px; border: 1.5px solid #e0e0e0; border-radius: 10px; cursor: pointer; font-size: 15px; transition: all 0.15s; background: white; text-align: left; width: 100%; }
    .opt:hover { border-color: #1a6b3a; background: #f0faf4; }
    .opt.selected { border-color: #1a6b3a; background: #e8f5ed; font-weight: 600; color: #1a6b3a; }
    .btn-next { background: #1a6b3a; color: white; border: none; padding: 13px 32px; border-radius: 10px; font-size: 15px; font-weight: 600; cursor: pointer; margin-top: 10px; width: 100%; }
    .btn-next:disabled { background: #ccc; cursor: default; }
    .results { display: none; }
    .result-card { background: white; border: 1px solid #e0e0e0; border-radius: 14px; padding: 20px; margin-bottom: 14px; display: flex; justify-content: space-between; align-items: center; }
    .result-rank { font-family: 'Sora', sans-serif; font-size: 24px; font-weight: 700; color: #1a6b3a; min-width: 40px; }
    .result-info { flex: 1; padding: 0 16px; }
    .result-name { font-family: 'Sora', sans-serif; font-size: 18px; font-weight: 700; margin-bottom: 3px; }
    .result-why { font-size: 13px; color: #666; }
    .result-score { font-size: 22px; font-weight: 700; color: #1a6b3a; }
    .share-bar { background: #f0faf4; border: 1px solid #c0ddc8; border-radius: 12px; padding: 16px 20px; margin-top: 24px; text-align: center; }
    .ad-quiz { background: #f0f0ee; border-radius: 10px; padding: 12px; text-align: center; margin: 24px 0; min-height: 90px; }
  </style>
</head>
<body>

  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="logo">
        <span class="logo-mark">S</span>
        <span class="logo-text">SuburbScout</span>
      </a>
      <nav class="nav">
        <a href="/compare">Compare</a>
        <a href="/quiz" style="color:white;font-weight:700">Find My Suburb</a>
        <a href="/top-10">Top 10 Lists</a>
      </nav>
    </div>
  </header>

  <div class="quiz-wrap">
    <h1 class="quiz-title">Find your perfect suburb</h1>
    <p class="quiz-sub">Answer 8 quick questions and we'll match you with the best Australian suburbs for your lifestyle.</p>

    <div class="progress-bar-bg">
      <div class="progress-bar-fill" id="progressBar" style="width: 0%"></div>
    </div>

    <div id="quizArea">
      <!-- Questions rendered by JS -->
    </div>

    <!-- Ad shown mid-quiz -->
    <div class="ad-quiz" id="midAd" style="display:none">
      <p style="font-size:10px;color:#aaa;text-transform:uppercase;margin-bottom:4px">Advertisement</p>
      <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-XXXXXXXXXXXXXXXX" data-ad-slot="7788990011" data-ad-format="auto" data-full-width-responsive="true"></ins>
    </div>

    <div class="results" id="results">
      <h2 style="font-family:'Sora',sans-serif;font-size:24px;font-weight:700;margin-bottom:6px">Your suburb matches</h2>
      <p style="font-size:14px;color:#666;margin-bottom:20px">Based on your answers, here are your top suburb recommendations:</p>
      <div id="resultsList"></div>
      <div class="share-bar">
        <p style="font-weight:600;margin-bottom:8px">Share your results</p>
        <button onclick="shareResults()" style="background:#1a6b3a;color:white;border:none;padding:10px 24px;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer">Share my suburb match</button>
      </div>
    </div>
  </div>

  <script>
    const QUESTIONS = [
      {
        id: 'state',
        text: 'Which state are you looking in?',
        options: [
          { label: 'New South Wales', value: 'NSW', tags: { state: 'NSW' } },
          { label: 'Victoria', value: 'VIC', tags: { state: 'VIC' } },
          { label: 'Queensland', value: 'QLD', tags: { state: 'QLD' } },
          { label: 'Western Australia', value: 'WA', tags: { state: 'WA' } },
          { label: 'South Australia', value: 'SA', tags: { state: 'SA' } },
          { label: 'Open to anywhere', value: 'ANY', tags: {} },
        ]
      },
      {
        id: 'budget',
        text: "What's your budget or max rent?",
        options: [
          { label: 'Renting under $400/wk', value: 'rent_low', tags: { rating_affordability_rent_min: 7 } },
          { label: 'Renting $400–$600/wk', value: 'rent_mid', tags: { rating_affordability_rent_min: 4 } },
          { label: 'Renting $600+/wk', value: 'rent_high', tags: {} },
          { label: 'Buying under $800k', value: 'buy_low', tags: { rating_affordability_buy_min: 6 } },
          { label: 'Buying $800k–$1.5m', value: 'buy_mid', tags: { rating_affordability_buy_min: 3 } },
          { label: 'Buying $1.5m+', value: 'buy_high', tags: {} },
        ]
      },
      {
        id: 'lifestyle',
        text: 'Which lifestyle matters most to you?',
        options: [
          { label: 'Buzzing cafes, bars & nightlife', value: 'vibrant', tags: { rating_things_to_do_min: 7 } },
          { label: 'Quiet and peaceful', value: 'quiet', tags: { rating_noise_min: 7 } },
          { label: 'Nature, parks and outdoors', value: 'nature', tags: { rating_nature_min: 7 } },
          { label: 'Family-friendly and safe', value: 'family', tags: { rating_family_min: 7, rating_safety_min: 7 } },
          { label: 'Mix of everything', value: 'balanced', tags: { scout_score_min: 6 } },
        ]
      },
      {
        id: 'commute',
        text: 'How long are you willing to commute to the CBD?',
        options: [
          { label: 'Under 15 minutes', value: 'vclose', tags: { commute_train_max: 15 } },
          { label: '15–30 minutes', value: 'close', tags: { commute_train_max: 30 } },
          { label: '30–45 minutes', value: 'medium', tags: { commute_train_max: 45 } },
          { label: 'Happy to drive — no preference', value: 'any', tags: {} },
        ]
      },
      {
        id: 'safety',
        text: 'How important is low crime to you?',
        options: [
          { label: 'Top priority — must be very safe', value: 'critical', tags: { rating_safety_min: 9 } },
          { label: 'Important but not the only factor', value: 'important', tags: { rating_safety_min: 6 } },
          { label: "I'm comfortable in busier areas", value: 'flexible', tags: {} },
        ]
      },
      {
        id: 'schools',
        text: 'Do you need good schools nearby?',
        options: [
          { label: 'Yes — primary schools', value: 'primary', tags: { has_schools: true } },
          { label: 'Yes — secondary schools', value: 'secondary', tags: { has_schools: true } },
          { label: 'Both primary and secondary', value: 'both', tags: { has_schools: true } },
          { label: 'Not important to me', value: 'no', tags: {} },
        ]
      },
      {
        id: 'transport',
        text: 'How do you get around?',
        options: [
          { label: 'Train is essential', value: 'train', tags: { rating_transport_min: 7 } },
          { label: 'Bus or tram is fine', value: 'bus', tags: { rating_transport_min: 5 } },
          { label: 'I drive everywhere', value: 'car', tags: {} },
          { label: 'I want to walk everywhere', value: 'walk', tags: { commute_train_max: 15, rating_things_to_do_min: 6 } },
        ]
      },
      {
        id: 'risk',
        text: 'Any environmental risks you want to avoid?',
        options: [
          { label: 'Avoid flood risk areas', value: 'no_flood', tags: { flood_risk_max: 'low' } },
          { label: 'Avoid bushfire risk areas', value: 'no_fire', tags: { bushfire_risk_max: 'low' } },
          { label: 'Avoid both', value: 'avoid_both', tags: { flood_risk_max: 'low', bushfire_risk_max: 'low' } },
          { label: 'Not fussed', value: 'any', tags: {} },
        ]
      },
    ];

    let currentQ = 0;
    let answers = {};

    function renderQuestion() {
      const q = QUESTIONS[currentQ];
      const pct = (currentQ / QUESTIONS.length) * 100;
      document.getElementById('progressBar').style.width = pct + '%';

      document.getElementById('quizArea').innerHTML = `
        <div class="question-card">
          <div class="q-num">Question ${currentQ + 1} of ${QUESTIONS.length}</div>
          <div class="q-text">${q.text}</div>
          <div class="options" id="opts">
            ${q.options.map((o, i) => `
              <button class="opt" onclick="selectOpt(${i})" data-idx="${i}">${o.label}</button>
            `).join('')}
          </div>
          <button class="btn-next" id="nextBtn" onclick="nextQuestion()" disabled>
            ${currentQ === QUESTIONS.length - 1 ? 'See my matches →' : 'Next question →'}
          </button>
        </div>
      `;
    }

    function selectOpt(idx) {
      document.querySelectorAll('.opt').forEach(b => b.classList.remove('selected'));
      document.querySelectorAll('.opt')[idx].classList.add('selected');
      answers[QUESTIONS[currentQ].id] = QUESTIONS[currentQ].options[idx];
      document.getElementById('nextBtn').disabled = false;
    }

    function nextQuestion() {
      if (currentQ < QUESTIONS.length - 1) {
        currentQ++;
        renderQuestion();
        if (currentQ === 4) {
          document.getElementById('midAd').style.display = 'block';
          (adsbygoogle = window.adsbygoogle || []).push({});
        }
      } else {
        showResults();
      }
    }

    function showResults() {
      document.getElementById('progressBar').style.width = '100%';
      document.getElementById('quizArea').style.display = 'none';

      // Build result tags from answers
      const tags = {};
      Object.values(answers).forEach(a => Object.assign(tags, a.tags));

      // In a real build, this would query the suburb collection
      // For now, show smart placeholder results based on state + lifestyle
      const stateChoice = answers.state?.value || 'NSW';
      const lifestyleChoice = answers.lifestyle?.value || 'balanced';

      const mockResults = getMockResults(stateChoice, lifestyleChoice);

      document.getElementById('resultsList').innerHTML = mockResults.map((r, i) => `
        <div class="result-card">
          <div class="result-rank">#${i + 1}</div>
          <div class="result-info">
            <div class="result-name">${r.name}, ${r.state}</div>
            <div class="result-why">${r.why}</div>
          </div>
          <div>
            <div class="result-score">${r.score}</div>
            <div style="font-size:11px;color:#999;text-align:center">match</div>
          </div>
          <a href="/${r.state.toLowerCase()}/${r.slug}" style="margin-left:12px;background:#e8f5ed;color:#1a6b3a;padding:8px 12px;border-radius:8px;font-size:13px;font-weight:600;white-space:nowrap">View profile →</a>
        </div>
      `).join('');

      document.getElementById('results').style.display = 'block';
      document.getElementById('results').scrollIntoView({ behavior: 'smooth' });
    }

    function getMockResults(state, lifestyle) {
      const pools = {
        NSW: {
          vibrant: [
            { name: 'Surry Hills', slug: 'surry-hills-nsw', state: 'NSW', score: '96%', why: 'Iconic cafe culture, great transport, walkable inner city' },
            { name: 'Newtown', slug: 'newtown-nsw', state: 'NSW', score: '92%', why: 'Eclectic vibe, strong arts scene, excellent King St dining' },
            { name: 'Glebe', slug: 'glebe-nsw', state: 'NSW', score: '88%', why: 'Quieter than Newtown but still lively, close to CBD' },
          ],
          quiet: [
            { name: 'Mosman', slug: 'mosman-nsw', state: 'NSW', score: '94%', why: 'Low crime, peaceful harbourside, excellent schools' },
            { name: 'Pymble', slug: 'pymble-nsw', state: 'NSW', score: '89%', why: 'Green and quiet, large homes, very safe' },
            { name: 'Chatswood', slug: 'chatswood-nsw', state: 'NSW', score: '85%', why: 'Quiet residential feel with great train access' },
          ],
          family: [
            { name: 'Mosman', slug: 'mosman-nsw', state: 'NSW', score: '95%', why: 'Top schools, safe streets, family amenities' },
            { name: 'Balmain', slug: 'balmain-nsw', state: 'NSW', score: '90%', why: 'Village feel, good schools, safe community' },
            { name: 'Leichhardt', slug: 'leichhardt-nsw', state: 'NSW', score: '86%', why: 'Family-friendly, Italian community, good parks' },
          ],
          nature: [
            { name: 'Manly', slug: 'manly-nsw', state: 'NSW', score: '97%', why: 'Beach, national park access, outdoor lifestyle' },
            { name: 'Glebe', slug: 'glebe-nsw', state: 'NSW', score: '83%', why: 'Close to parks and bay, inner-city nature balance' },
            { name: 'Balmain', slug: 'balmain-nsw', state: 'NSW', score: '81%', why: 'Harbourside, walkable foreshore, leafy streets' },
          ],
          balanced: [
            { name: 'Paddington', slug: 'paddington-nsw', state: 'NSW', score: '91%', why: 'Great balance of cafes, safety, style and transport' },
            { name: 'Balmain', slug: 'balmain-nsw', state: 'NSW', score: '88%', why: 'Village charm with city convenience' },
            { name: 'Newtown', slug: 'newtown-nsw', state: 'NSW', score: '84%', why: 'Diverse, lively and affordable for inner Sydney' },
          ],
        },
        VIC: {
          vibrant: [
            { name: 'Fitzroy', slug: 'fitzroy-vic', state: 'VIC', score: '95%', why: 'Melbourne\'s creative heartland, incredible dining and bars' },
            { name: 'Collingwood', slug: 'collingwood-vic', state: 'VIC', score: '91%', why: 'Arts, hospitality and nightlife in one suburb' },
            { name: 'Richmond', slug: 'richmond-vic', state: 'VIC', score: '87%', why: 'Bridge Rd shopping, sports precinct, buzzy vibe' },
          ],
          quiet: [
            { name: 'Hawthorn', slug: 'hawthorn-vic', state: 'VIC', score: '93%', why: 'Leafy streets, historic homes, quiet and prestigious' },
            { name: 'South Yarra', slug: 'south-yarra-vic', state: 'VIC', score: '89%', why: 'Elegant, green and close to the CBD' },
            { name: 'Prahran', slug: 'prahran-vic', state: 'VIC', score: '84%', why: 'Upmarket and quiet despite central location' },
          ],
          balanced: [
            { name: 'South Yarra', slug: 'south-yarra-vic', state: 'VIC', score: '92%', why: 'Perfect mix of lifestyle, transport and prestige' },
            { name: 'Brunswick', slug: 'brunswick-vic', state: 'VIC', score: '88%', why: 'Affordable, lively, excellent tram access' },
            { name: 'Hawthorn', slug: 'hawthorn-vic', state: 'VIC', score: '85%', why: 'Established suburb with excellent amenities' },
          ],
          family: [
            { name: 'Hawthorn', slug: 'hawthorn-vic', state: 'VIC', score: '94%', why: 'Excellent schools, safe, great family parks' },
            { name: 'South Yarra', slug: 'south-yarra-vic', state: 'VIC', score: '89%', why: 'Green, safe and well-resourced for families' },
            { name: 'Richmond', slug: 'richmond-vic', state: 'VIC', score: '83%', why: 'Convenient for families, sports facilities nearby' },
          ],
          nature: [
            { name: 'Brunswick', slug: 'brunswick-vic', state: 'VIC', score: '80%', why: 'Good park access, Merri Creek corridor nearby' },
            { name: 'Hawthorn', slug: 'hawthorn-vic', state: 'VIC', score: '86%', why: 'Leafy streets, Yarra River access' },
            { name: 'South Yarra', slug: 'south-yarra-vic', state: 'VIC', score: '88%', why: 'Botanical Gardens, Fawkner Park on your doorstep' },
          ],
        }
      };

      const statePool = pools[state] || pools['NSW'];
      return (statePool[lifestyle] || statePool['balanced']);
    }

    function shareResults() {
      const url = window.location.href;
      if (navigator.share) {
        navigator.share({ title: 'My suburb match on SuburbScout', url });
      } else {
        navigator.clipboard.writeText(url).then(() => alert('Link copied to clipboard!'));
      }
    }

    renderQuestion();
  </script>

</body>
</html>
